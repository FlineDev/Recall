{
  "description": "Recall: automatic context recovery after compaction. PreCompact generates the transcript into .claude/recall-context.md (pulled in via CLAUDE.md @-reference). SessionStart(compact) reminds Claude to act on it. SessionStart (all) cleans up the file.",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/recall/scripts/pre-compact.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/recall/scripts/post-compact.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/recall/scripts/session-start.sh"
          }
        ]
      }
    ]
  }
}
